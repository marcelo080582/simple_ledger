<div class="container">
  <% if notice.present? %>
    <div class="alert alert-success">
      <%= notice %>
    </div>
  <% end %>

  <% if alert.present? %>
    <div class="alert alert-error">
      <%= alert %>
    </div>
  <% end %>

  <h1 class="page-title">Simple Ledger</h1>

  <div class="grid">
    <div class="card">
      <h2 class="card-title">Create Account</h2>

      <%= form_with model: Account.new, url: accounts_path, local: true do |form| %>
        <div class="form-group">
          <%= form.label :name %>
          <%= form.text_field :name, class: "input", placeholder: "Ex: Cash, Bank, Revenue..." %>
        </div>

        <div class="form-group">
          <%= form.label :direction %>
          <%= form.select :direction, Account.directions.keys.map { |direction| [direction.titleize, direction] }, {}, class: "input" %>
        </div>

        <%= form.submit "Create Account", class: "button" %>
      <% end %>
    </div>

    <div class="card">
      <h2 class="card-title">Accounts</h2>

      <ul class="accounts-list">
        <% @accounts.each do |account| %>
          <li class="account-item">
            <div>
              <strong><%= account.name %></strong>
              —
              <%= account.direction.titleize %>
            </div>

            <div class="account-balance">
              <%= number_to_currency(account.balance_cents / 100.0) %>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

  <div class="card transaction-card">
    <h2 class="card-title">Create Transaction</h2>

    <%= form_with url: ledger_transactions_path, scope: :ledger_transaction, local: true do |form| %>
      <div class="form-group">
        <%= form.label :name, "Transaction name" %>
        <%= form.text_field :name, class: "input", placeholder: "Ex: Sale, Payment..." %>
      </div>

      <div class="entries-grid">
        <div>
          <h3>Debit entry</h3>

          <div class="form-group">
            <%= label_tag "debit_account_id", "Account" %>
            <%= select_tag "ledger_transaction[entries_attributes][][account_id]",
                           options_from_collection_for_select(@accounts, :id, :name),
                           class: "input" %>
          </div>

          <%= hidden_field_tag "ledger_transaction[entries_attributes][][direction]", "debit" %>

          <div class="form-group">
            <%= label_tag "debit_amount_cents", "Amount cents" %>
            <%= number_field_tag "ledger_transaction[entries_attributes][][amount_cents]",
                                 nil,
                                 class: "input",
                                 min: 1 %>
          </div>
        </div>

        <div>
          <h3>Credit entry</h3>

          <div class="form-group">
            <%= label_tag "credit_account_id", "Account" %>
            <%= select_tag "ledger_transaction[entries_attributes][][account_id]",
                           options_from_collection_for_select(@accounts, :id, :name),
                           class: "input" %>
          </div>

          <%= hidden_field_tag "ledger_transaction[entries_attributes][][direction]", "credit" %>

          <div class="form-group">
            <%= label_tag "credit_amount_cents", "Amount cents" %>
            <%= number_field_tag "ledger_transaction[entries_attributes][][amount_cents]",
                                 nil,
                                 class: "input",
                                 min: 1 %>
          </div>
        </div>
      </div>

      <%= form.submit "Create Transaction", class: "button" %>
    <% end %>
  </div>

  <div class="card transaction-card">
    <h2 class="card-title">Transactions</h2>

    <% if @ledger_transactions.any? %>
      <% @ledger_transactions.each do |ledger_transaction| %>
        <div class="transaction-item">
          <strong><%= ledger_transaction.name %></strong>

          <ul>
            <% ledger_transaction.entries.each do |entry| %>
              <li>
                <%= entry.direction.titleize %>
                —
                <%= entry.account.name %>
                —
                <%= entry.amount_cents %> cents
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    <% else %>
      <p>No transactions yet.</p>
    <% end %>
  </div>
</div>
